{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../public",
    "distDir": "../public"
  },
  "package": {
    "productName": "Buddy",
    "version": "1.1.0"
  },
  "tauri": {
    "identifier": "com.buddy.chat",
    "windows": [
      {
        "label": "main",
        "title": "Buddy",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "displayLanguageSelector": false,
          "allowToChangeInstallationDirectory": true
        }
      }
    }
  }
}
